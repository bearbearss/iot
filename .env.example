# ============================================================
# 환경 변수 설정 파일 예시
# 이 파일을 복사하여 .env 파일을 만드세요:
#   cp .env.example .env
# 그리고 아래 값을 실제 값으로 변경하세요.
# .env 파일은 .gitignore에 포함되어 GitHub에 업로드되지 않습니다.
# ============================================================

# 보호자가 입력하는 접근 코드 (숫자 또는 문자, 원하는 값으로 설정)
ACCESS_CODE=1234

# Flask 세션 서명에 사용하는 비밀 키
# 반드시 아래처럼 긴 랜덤 문자열로 바꾸세요
# 생성 명령어: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string
